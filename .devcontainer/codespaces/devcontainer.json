{
  "name": "Presence DevContainer for Codespaces",
  
  "image": "mcr.microsoft.com/devcontainers/base:bookworm",

  "features": {
    "ghcr.io/devcontainers-contrib/features/direnv": {},
    "ghcr.io/devcontainers/features/github-cli": {}
  },

  "postCreateCommand": "./.devcontainer/codespaces/post-create.sh",

  "forwardPorts": [
    10080,
    10443
  ],

  "portsAttributes": {
    "10080": {
      "visibility": "public"
    },
    "10443": {
      "visibility": "public"
    }
  },

  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3"
      },
      "extensions": [
          "ms-azuretools.vscode-docker",

          "github.copilot",
          "github.copilot-chat",

          "aws-scripting-guy.cform",

          "ms-python.python",
          "ms-python.vscode-pylance",
          
          "mkhl.direnv",

          "jetpack-io.devbox"
        
      ]
    }
  },
  "remoteUser": "vscode"
}
